<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/navControls"
    android:layout_width="0dp"
    android:layout_height="match_parent"
    android:layout_weight="1"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center"
    android:orientation="vertical">

    <ImageView
        android:id="@+id/navControlsIcon"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:src="@drawable/ic_nav_controls"
        android:tint="@color/bottom_nav_inactive" />

    <TextView
        android:id="@+id/navControlsLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/tab_controls"
        android:textColor="@color/bottom_nav_inactive"
        android:textSize="11sp"
        android:textStyle="bold" />
</LinearLayout>