<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp" android:paddingBottom="32dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
            <com.google.android.material.button.MaterialButton android:id="@+id/backButton" style="@style/Widget.Material3.Button.TextButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Voltar" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="@string/photo_detail_title" android:textColor="@color/theme_primary_text" android:textSize="22sp" android:textStyle="bold" />
        </LinearLayout>
        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" app:cardBackgroundColor="@color/theme_surface" app:cardCornerRadius="28dp" app:strokeColor="@color/theme_border" app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                <FrameLayout android:layout_width="120dp" android:layout_height="120dp" android:layout_gravity="center_horizontal" android:background="@drawable/avatar_bubble" android:padding="24dp"><ImageView android:id="@+id/photoArtwork" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_gravity="center" android:src="@drawable/ic_nav_photo" /></FrameLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="18dp" android:text="@string/photo_detail_album" android:textColor="@color/theme_secondary_text" android:textSize="12sp" android:textStyle="bold" />
                <TextView android:id="@+id/photoAlbum" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:textColor="@color/theme_primary_text" android:textSize="18sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="@string/photo_detail_status" android:textColor="@color/theme_secondary_text" android:textSize="12sp" android:textStyle="bold" />
                <TextView android:id="@+id/photoStatus" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:textColor="@color/theme_primary_text" android:textSize="16sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="@string/photo_detail_date" android:textColor="@color/theme_secondary_text" android:textSize="12sp" android:textStyle="bold" />
                <TextView android:id="@+id/photoDate" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:textColor="@color/theme_primary_text" android:textSize="16sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="@string/photo_detail_reason" android:textColor="@color/theme_secondary_text" android:textSize="12sp" android:textStyle="bold" />
                <TextView android:id="@+id/photoReason" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:textColor="@color/theme_primary_text" android:textSize="16sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="@string/photo_detail_note" android:textColor="@color/theme_secondary_text" android:textSize="12sp" android:textStyle="bold" />
                <TextView android:id="@+id/photoNote" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:textColor="@color/theme_primary_text" android:textSize="16sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>