<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp" android:paddingBottom="120dp">
        <com.google.android.material.card.MaterialCardView android:id="@+id/latestPhotoCard" android:layout_width="match_parent" android:layout_height="wrap_content" app:cardBackgroundColor="@color/theme_surface" app:cardCornerRadius="28dp" app:strokeColor="@color/theme_border" app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/photo_card_title" android:textColor="@color/theme_primary_text" android:textSize="22sp" android:textStyle="bold" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="@string/photo_card_description" android:textColor="@color/theme_secondary_text" android:textSize="14sp" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="18dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <FrameLayout android:layout_width="92dp" android:layout_height="92dp" android:background="@drawable/avatar_bubble" android:padding="5dp">
                        <ImageView android:id="@+id/photoPreview" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_gravity="center" android:background="@drawable/avatar_clip" android:clipToOutline="true" android:scaleType="centerCrop" android:src="@drawable/ic_nav_photo" app:tint="@color/theme_primary_dark" />
                    </FrameLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:id="@+id/latestAlbumBadge" android:layout_width="wrap_content" android:layout_height="wrap_content" android:paddingStart="10dp" android:paddingTop="5dp" android:paddingEnd="10dp" android:paddingBottom="5dp" android:text="@string/photo_album_today" android:textColor="@color/theme_primary_text" android:textSize="11sp" android:textStyle="bold" />
                        <TextView android:id="@+id/photoStatusTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="@string/photo_pending_title" android:textColor="@color/theme_primary_text" android:textSize="18sp" android:textStyle="bold" />
                        <TextView android:id="@+id/photoStatusBody" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="@string/photo_pending_body" android:textColor="@color/theme_secondary_text" android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="18dp" android:orientation="horizontal">
                    <com.google.android.material.button.MaterialButton android:id="@+id/takePhotoButton" style="@style/Widget.Material3.Button" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginEnd="6dp" android:layout_weight="1" android:text="@string/take_photo" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/openLatestButton" style="@style/Widget.Material3.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="6dp" android:layout_weight="1" android:text="@string/open_latest_photo" />
                </LinearLayout>
                <TextView android:id="@+id/photoCaption" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="@string/photo_empty" android:textColor="@color/theme_secondary_text" android:textSize="13sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:orientation="horizontal">
            <com.google.android.material.card.MaterialCardView android:id="@+id/todayAlbumCard" android:layout_width="0dp" android:layout_height="168dp" android:layout_marginEnd="6dp" android:layout_weight="1" app:cardBackgroundColor="@color/theme_surface" app:cardCornerRadius="24dp" app:strokeColor="@color/theme_border" app:strokeWidth="1dp"><LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="16dp"><TextView android:id="@+id/todayBadge" android:layout_width="wrap_content" android:layout_height="wrap_content" android:paddingStart="10dp" android:paddingTop="5dp" android:paddingEnd="10dp" android:paddingBottom="5dp" android:text="@string/photo_album_today" android:textColor="@color/theme_primary_text" android:textSize="11sp" android:textStyle="bold" /><TextView android:id="@+id/todayCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:text="@string/photo_count_empty" android:textColor="@color/theme_primary_dark" android:textSize="28sp" android:textStyle="bold" /><TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="@string/photo_album_today_hint" android:textColor="@color/theme_secondary_text" android:textSize="12sp" /></LinearLayout></com.google.android.material.card.MaterialCardView>
            <com.google.android.material.card.MaterialCardView android:id="@+id/weekAlbumCard" android:layout_width="0dp" android:layout_height="168dp" android:layout_marginStart="6dp" android:layout_weight="1" app:cardBackgroundColor="@color/theme_surface" app:cardCornerRadius="24dp" app:strokeColor="@color/theme_border" app:strokeWidth="1dp"><LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="16dp"><TextView android:id="@+id/weekBadge" android:layout_width="wrap_content" android:layout_height="wrap_content" android:paddingStart="10dp" android:paddingTop="5dp" android:paddingEnd="10dp" android:paddingBottom="5dp" android:text="@string/photo_album_week" android:textColor="@color/theme_primary_text" android:textSize="11sp" android:textStyle="bold" /><TextView android:id="@+id/weekCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:text="@string/photo_count_empty" android:textColor="@color/theme_primary_dark" android:textSize="28sp" android:textStyle="bold" /><TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="@string/photo_album_week_hint" android:textColor="@color/theme_secondary_text" android:textSize="12sp" /></LinearLayout></com.google.android.material.card.MaterialCardView>
        </LinearLayout>
        <com.google.android.material.card.MaterialCardView android:id="@+id/eventsAlbumCard" android:layout_width="match_parent" android:layout_height="168dp" android:layout_marginTop="12dp" app:cardBackgroundColor="@color/theme_surface" app:cardCornerRadius="24dp" app:strokeColor="@color/theme_border" app:strokeWidth="1dp"><LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="16dp"><TextView android:id="@+id/eventsBadge" android:layout_width="wrap_content" android:layout_height="wrap_content" android:paddingStart="10dp" android:paddingTop="5dp" android:paddingEnd="10dp" android:paddingBottom="5dp" android:text="@string/photo_album_events" android:textColor="@color/theme_primary_text" android:textSize="11sp" android:textStyle="bold" /><TextView android:id="@+id/eventsCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:text="@string/photo_count_empty" android:textColor="@color/theme_primary_dark" android:textSize="28sp" android:textStyle="bold" /><TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="@string/photo_album_events_hint" android:textColor="@color/theme_secondary_text" android:textSize="12sp" /></LinearLayout></com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
