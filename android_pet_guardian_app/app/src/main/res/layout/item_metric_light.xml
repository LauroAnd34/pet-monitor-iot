<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_weight="1"
    android:layout_marginStart="6dp"
    android:orientation="vertical">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="190dp"
        app:cardBackgroundColor="@color/theme_surface"
        app:cardCornerRadius="22dp"
        app:strokeColor="@color/theme_border"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Luz ambiente"
                android:textColor="@color/theme_secondary_text"
                android:textSize="12sp"
                android:textStyle="bold" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="8dp">

                <View
                    android:id="@+id/lightPulse"
                    android:layout_width="78dp"
                    android:layout_height="78dp"
                    android:layout_gravity="center"
                    android:alpha="0.35"
                    android:background="@drawable/status_dot" />

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/lightProgress"
                    android:layout_width="84dp"
                    android:layout_height="84dp"
                    android:layout_gravity="center"
                    android:indeterminate="false"
                    app:indicatorColor="@color/theme_primary"
                    app:indicatorSize="84dp"
                    app:trackColor="@color/theme_border"
                    app:trackThickness="9dp" />

                <ImageView
                    android:id="@+id/lightIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_metric_light"
                    android:tint="@color/theme_primary_text" />
            </FrameLayout>

            <TextView
                android:id="@+id/lightValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="@color/theme_primary_text"
                android:textSize="21sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/lightState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:minLines="1"
                android:textColor="@color/theme_secondary_text"
                android:textSize="13sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
