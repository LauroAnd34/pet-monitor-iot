<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/theme_surface"
            app:cardCornerRadius="28dp"
            app:strokeColor="@color/theme_border"
            app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/theme_section_title" android:textColor="@color/theme_primary_text" android:textSize="22sp" android:textStyle="bold" /><TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="@string/theme_section_description" android:textColor="@color/theme_secondary_text" android:textSize="14sp" /></LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:orientation="horizontal"><include layout="@layout/item_theme_blossom" /><include layout="@layout/item_theme_mint" /></LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:orientation="horizontal"><include layout="@layout/item_theme_butter" /><include layout="@layout/item_theme_cocoa" /></LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:orientation="horizontal"><include layout="@layout/item_theme_lavender" /><include layout="@layout/item_theme_ocean" /></LinearLayout>
    </LinearLayout>
</ScrollView>