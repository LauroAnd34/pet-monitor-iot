<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/actionWaterCard"
    android:layout_width="120dp"
    android:layout_height="104dp"
    android:layout_marginEnd="12dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/theme_surface"
    app:cardCornerRadius="24dp"
    app:rippleColor="@color/theme_mint_soft"
    app:strokeColor="@color/theme_border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="H2O" android:textSize="24sp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Agua" android:textColor="@color/theme_primary_text" android:textSize="16sp" android:textStyle="bold" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Acionar bomba" android:textColor="@color/theme_secondary_text" android:textSize="12sp" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
