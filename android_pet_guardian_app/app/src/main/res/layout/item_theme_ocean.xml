<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/themeOcean"
    android:layout_width="0dp"
    android:layout_height="136dp"
    android:layout_weight="1"
    android:layout_marginStart="6dp"
    app:cardBackgroundColor="@color/theme_surface"
    app:cardCornerRadius="24dp"
    app:strokeColor="@color/theme_border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:orientation="horizontal">
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#EAF8FF" />
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#A9D8F8" />
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#4DA1E2" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/theme_ocean"
            android:textColor="@color/theme_primary_text"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
