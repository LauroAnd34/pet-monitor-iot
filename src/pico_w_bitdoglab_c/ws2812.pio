.program ws2812
.side_set 1

.define public T1 2
.define public T2 5
.define public T3 3

.lang_opt python sideset_init = pico.PIO.OUT_LOW
.lang_opt python out_shiftdir = 1
.lang_opt python autopull = true
.lang_opt python pull_thresh = 24

.wrap_target
bitloop:
    out x, 1       side 0 [T3 - 1]
    jmp !x do_zero side 1 [T1 - 1]
    jmp bitloop    side 1 [T2 - 1]
do_zero:
    nop            side 0 [T2 - 1]
.wrap
